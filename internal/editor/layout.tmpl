{{define "layout"}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Flag Manager</title>
    <script>
        (function() {
            function getInitialTheme() {
                var saved = localStorage.getItem('theme');
                if (saved) return saved;
                return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
            }
            document.documentElement.setAttribute('data-theme', getInitialTheme());
        })();
    </script>
    <link rel="stylesheet" href="/editor.css">
    <script src="https://unpkg.com/htmx.org@1.9.12" defer></script>
    <script src="https://unpkg.com/marked@12.0.2/marked.min.js" defer></script>
</head>
<body>
    <div class="app">
        <div class="app-header">
        <header class="topbar">
            <a href="/" class="topbar__brand" aria-label="Flag manager home">
                <span class="topbar__brand-mark" aria-hidden="true"></span>
                Flag Manager
            </a>
            {{block "breadcrumb" .}}{{end}}
            <div class="topbar__spacer"></div>
            <div class="topbar__actions">
                <div class="topbar__action">
                    <button id="chat-shortcut-hint" type="button" class="topbar__shortcut"></button>
                    <button id="chat-toggle" type="button" class="btn btn--ghost btn--icon" aria-label="Open assistant chat" title="Assistant chat">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    </button>
                </div>
                <div class="topbar__action">
                    <button id="theme-shortcut-hint" type="button" class="topbar__shortcut"></button>
                    <button id="theme-toggle" type="button" class="btn btn--ghost btn--icon theme-toggle" aria-label="Toggle theme" title="Toggle theme">
                        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
                        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                    </button>
                </div>
            </div>
        </header>

        {{block "toolbar" .}}{{end}}
        </div>

        <main class="page">
            {{template "main" .}}
        </main>
    </div>

    <div id="toast-region" aria-live="polite" aria-atomic="true"></div>

    <div id="chat-overlay" class="assistant-overlay" aria-hidden="true">
        <div class="assistant-backdrop"></div>
        <aside class="assistant-panel" role="dialog" aria-labelledby="chat-panel-title" aria-modal="true">
            <div class="assistant-panel__header">
                <div class="assistant-panel__brand">
                    <span class="assistant-panel__icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/><path d="M5 3v4"/><path d="M19 17v4"/><path d="M3 5h4"/><path d="M17 19h4"/></svg>
                    </span>
                    <span id="chat-panel-title" class="assistant-panel__title">Assistant</span>
                </div>
                <button id="auth-logout-btn" type="button" class="btn btn--ghost btn--sm" title="Disconnect OpenRouter" hidden>Disconnect</button>
                <button id="chat-close" type="button" class="btn btn--ghost btn--icon" aria-label="Close chat">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </button>
            </div>
            <div class="assistant-panel__columns">
                <div class="chat-panel__body">
                    <div id="chat-messages" class="chat-messages" aria-live="polite"></div>
                    <div id="chat-status" class="chat-status"></div>
                    <div id="chat-connect" class="chat-connect">
                        <button id="auth-login-btn" type="button" class="btn btn--primary">Connect OpenRouter</button>
                    </div>
                    <form id="chat-form" class="chat-form" hidden>
                        <div class="model-picker" id="model-picker">
                            <button id="model-picker-trigger" type="button" class="model-picker__trigger" aria-haspopup="listbox" aria-expanded="false" aria-label="Select model">
                                <svg class="model-picker__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 9h6v6H9z"/><path d="M9 1v3"/><path d="M15 1v3"/><path d="M9 20v3"/><path d="M15 20v3"/><path d="M1 9h3"/><path d="M1 15h3"/><path d="M20 9h3"/><path d="M20 15h3"/></svg>
                                <span class="model-picker__label" id="model-picker-label">Loading model…</span>
                                <svg class="model-picker__caret" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 15 12 9 18 15"/></svg>
                            </button>
                            <div id="model-picker-menu" class="model-picker__menu" role="dialog" aria-label="Choose model" hidden>
                                <div class="model-picker__search-row">
                                    <svg class="model-picker__search-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
                                    <input id="model-picker-search" class="model-picker__search" type="text" placeholder="Search models…" autocomplete="off" spellcheck="false" />
                                    <button id="model-picker-sort" type="button" class="model-picker__sort" aria-label="Change sort order">
                                        <svg class="model-picker__sort-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 16 4 4 4-4"/><path d="M7 20V4"/><path d="m21 8-4-4-4 4"/><path d="M17 4v16"/></svg>
                                        <span class="model-picker__sort-label" id="model-picker-sort-label">A–Z</span>
                                    </button>
                                </div>
                                <div id="model-picker-chips" class="model-picker__chips" role="group" aria-label="Quick filters"></div>
                                <div id="model-picker-list" class="model-picker__list" role="listbox" tabindex="-1"></div>
                                <div id="model-picker-status" class="model-picker__status" hidden></div>
                            </div>
                        </div>
                        <div class="chat-composer">
                            <textarea id="chat-input" rows="1" placeholder="Ask about your flags…" aria-label="Chat message"></textarea>
                            <button type="submit" class="btn btn--primary chat-composer__send">Send</button>
                        </div>
                    </form>
                </div>
                <aside class="chat-list-pane" aria-label="Chats">
                    <div id="chat-list" class="chat-list" role="list"></div>
                    <button id="chat-new-btn" type="button" class="chat-list__new" title="New chat">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                        New chat
                    </button>
                </aside>
            </div>
        </aside>
    </div>

    <script>
        (function() {
            var btn = document.getElementById('theme-toggle');
            var root = document.documentElement;
            if (btn) {
                btn.addEventListener('click', function() {
                    var cur = root.getAttribute('data-theme') || 'light';
                    var next = cur === 'dark' ? 'light' : 'dark';
                    root.setAttribute('data-theme', next);
                    localStorage.setItem('theme', next);
                });
            }

            var header = document.querySelector('.app-header');
            if (!header || typeof ResizeObserver === 'undefined') return;
            function syncHeaderHeight() {
                root.style.setProperty('--layout-header-h', header.offsetHeight + 'px');
            }
            syncHeaderHeight();
            new ResizeObserver(syncHeaderHeight).observe(header);
        })();

        document.body.addEventListener('htmx:afterSwap', function(evt) {
            var toast = evt.detail.target.querySelector ? evt.detail.target : null;
            if (!toast) return;
            toast.querySelectorAll('.toast').forEach(function(t) {
                setTimeout(function() {
                    t.classList.add('is-leaving');
                    setTimeout(function() { t.remove(); }, 220);
                }, 3200);
            });
        });
    </script>

    <script src="/editor.js" defer></script>
    <script src="/assistant.js" defer></script>
</body>
</html>
{{end}}

{{define "breadcrumb"}}{{end}}
{{define "toolbar"}}{{end}}
