{{define "breadcrumb"}}
    <span class="topbar__breadcrumb">
        <a href="/">Flags</a>
        <span class="sep">/</span>
        <strong>{{if .Flag.FlagName}}{{.Flag.FlagName}}{{else}}New flag{{end}}</strong>
    </span>
{{end}}

{{define "toolbar"}}
    <div class="edit-toolbar">
        <div class="edit-toolbar__left">
            <a href="/" class="btn btn--ghost btn--sm" aria-label="Back to flags">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                Back
            </a>
        </div>
        <div class="edit-toolbar__center">
            <span class="edit-toolbar__title">
                {{if .Flag.FlagName}}Editing: <strong>{{.Flag.FlagName}}</strong>{{else}}Creating new flag{{end}}
            </span>
        </div>
        <div class="edit-toolbar__right">
            {{if .Flag.FlagName}}
                <button
                    type="button"
                    class="btn btn--danger btn--sm confirm-btn"
                    data-confirm="idle"
                    data-flag="{{.Flag.FlagName}}"
                    hx-post="/delete"
                    hx-vals='{"flagName": "{{.Flag.FlagName}}"}'
                    hx-trigger="confirmed"
                >Delete</button>
            {{end}}
            <button type="submit" form="flag-form" class="btn btn--primary btn--sm">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                Save flag
            </button>
        </div>
    </div>
{{end}}

{{define "main"}}
    <form id="flag-form"
          action="/save"
          method="post"
          hx-post="/save"
          hx-target="#toast-region"
          hx-swap="beforeend"
          data-flag-form>
        <div class="edit-grid">
            <aside class="edit-grid__sidebar" aria-label="Flag editor sidebar">
                <section class="card">
                    <header class="card__header">
                        <div>
                            <div class="card__title">Flag details</div>
                            <div class="card__subtitle">Core metadata for this flag</div>
                        </div>
                    </header>
                    <div class="card__body">
                        <div class="field">
                            <label class="field__label" for="flagName">Flag name</label>
                            <input class="input input--mono" type="text" id="flagName" name="flagName"
                                   value="{{.Flag.FlagName}}"
                                   {{if .Flag.FlagName}}readonly{{end}}
                                   required
                                   placeholder="my-feature-flag">
                            <span class="field__hint">{{if .Flag.FlagName}}The name cannot be changed after creation.{{else}}Use a stable identifier &mdash; this can't be changed later.{{end}}</span>
                        </div>

                        <div class="field">
                            <label class="field__label" for="defaultVariant">Default variant</label>
                            <input class="input" type="text" id="defaultVariant" name="defaultVariant"
                                   value="{{.Flag.DefaultVariant}}"
                                   placeholder="e.g. control">
                        </div>

                        <div class="field" data-json-field>
                            <div class="field__label-row">
                                <label class="field__label" for="defaultValue">Default value (JSON)</label>
                                <button type="button" class="btn btn--ghost btn--sm" data-json-format>Format</button>
                            </div>
                            <textarea class="textarea textarea--mono" id="defaultValue" name="defaultValue" rows="4"
                                      spellcheck="false">{{.DefaultValueJSON}}</textarea>
                            <span class="field__error" data-json-error>Invalid JSON.</span>
                        </div>
                    </div>
                </section>

                <section class="card rule-toc-card">
                    <header class="card__header">
                        <div>
                            <div class="card__title">Rules overview</div>
                            <div class="card__subtitle">Jump to a rule</div>
                        </div>
                    </header>
                    <div class="card__body card__body--compact">
                        <nav id="rule-toc" class="rule-toc" aria-label="Rules table of contents">
                            <p class="rule-toc__empty" id="rule-toc-empty">No rules yet</p>
                        </nav>
                    </div>
                </section>
            </aside>

            <section class="card rules-card">
                <div class="rules-panel__sticky">
                    <header class="card__header">
                    <div>
                        <div class="card__title">Rules</div>
                        <div class="card__subtitle">Evaluated by priority &mdash; higher priority wins.</div>
                    </div>
                    <div class="card__header-actions">
                        <button type="button" class="btn btn--ghost btn--sm" data-rules-collapse-all aria-label="Collapse all rules">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
                            Collapse all
                        </button>
                        <button type="button" class="btn btn--ghost btn--sm" data-rules-expand-all aria-label="Expand all rules">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
                            Expand all
                        </button>
                    </div>
                    </header>
                    <div class="rules-panel__sticky-tools">
                        <div class="rules-search">
                        <span class="rules-search__icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                        </span>
                        <input id="rules-search-box" class="input" type="search" placeholder="Search rules by type, variant, or field…" autocomplete="off">
                    </div>
                        <p id="rules-search-empty" class="rules-search__empty" hidden>No rules match your search.</p>
                    </div>
                </div>
                <div class="card__body rules-card__body">
                    <div id="rule-builder"></div>
                    <textarea id="rules" name="rules" style="display:none;">{{.RulesJSON}}</textarea>
                </div>
            </section>
        </div>
    </form>
{{end}}
